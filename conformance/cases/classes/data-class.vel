# data class: value type, compared by value.
Terminal term = new Terminal()
func ck(str name, bool cond) void {
    if (cond) { term.println("ok " + name) } else { term.println("FAIL " + name) }
}

data class Point(int x, int y) {
    func sum() int { return x + y }
}

Point a = new Point(1, 2)
Point b = new Point(1, 2)
Point c = new Point(1, 3)

ck("value equal", a == b)
ck("value not equal", (a == c) == false)
ck("method", a.sum() == 3)
ck("field", a.x == 1)
