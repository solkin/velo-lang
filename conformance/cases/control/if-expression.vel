# if/then/else as an expression, including nesting and block form.
Terminal term = new Terminal()
func ck(str name, bool cond) void {
    if (cond) { term.println("ok " + name) } else { term.println("FAIL " + name) }
}

let x = 7
let s = if x > 0 then "pos" else "neg"
ck("if expr", s == "pos")

let y = if x > 10 then 1 else if x > 5 then 2 else 3
ck("nested if expr", y == 2)

let z = if x > 5 then { let t = x * 2; t + 1 } else 0
ck("block if expr", z == 15)
