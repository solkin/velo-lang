include "lang/terminal.vel";

# Actor class — like a regular class, but every instance lives on its own
# daemon thread. Construction (`new Counter(0)`) and method calls
# (`await counter.bump()`) are serialised through a private mailbox, so the
# actor's mutable state is implicitly thread-safe.

actor class Counter(int start) {
    int n = start;

    func bump() int {
        n += 1;
        n;
    };

    func value() int {
        n;
    };
};

actor[Counter] counter = new Counter(10);

# `await` is mandatory whenever you cross the actor boundary. The compiler
# rejects naked `counter.bump()` because `actor[Counter]` exposes no props.
term.println(await counter.value().str);
term.println(await counter.bump().str);
term.println(await counter.bump().str);
term.println(await counter.value().str);

# Spawn a second, independent counter to show that each actor owns its own state.
actor[Counter] other = new Counter(0);
term.println(await other.bump().str);
term.println(await counter.value().str);
