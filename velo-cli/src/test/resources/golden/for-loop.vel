# for over an integer range and over an array, with break/continue.
Terminal term = new Terminal()

# Range 0..5 (end exclusive): 0+1+2+3+4 = 10
int sum = 0
for i in 0..5 {
    sum += i
}
term.println(sum.str())

# break and continue inside a for; continue still runs the step.
# odd numbers below 10: 1+3+5+7+9 = 25
int odd = 0
for k in 0..100 {
    if (k >= 10) {
        break
    }
    if (k % 2 == 0) {
        continue
    }
    odd += k
}
term.println(odd.str())

# Iterate an array's elements: 7+8+9 = 24
array[int] xs = new array[int](3)
xs[0] = 7
xs[1] = 8
xs[2] = 9
int total = 0
for x in xs {
    total += x
}
term.println(total.str())

# Range bound can be any expression.
int n = 4
int fact = 1
for f in 1..n + 1 {
    fact *= f
}
term.println(fact.str())
