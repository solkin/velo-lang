# Random reproduces java.util.Random bit-for-bit; these values match the JVM.
include "lang/random.vel";
include "lang/bool.vel";

Terminal term = new Terminal();

func showInts(int seed) void {
    Random r = new Random(seed);
    str line = "nextInt:";
    int i = 0;
    while (i < 5) {
        line = line.con(" ").con(r.nextInt().str);
        i = i + 1;
    };
    term.println(line);
};

func showBound(int seed, int bound) void {
    Random r = new Random(seed);
    str line = "nextInt(".con(bound.str).con("):");
    int i = 0;
    while (i < 8) {
        line = line.con(" ").con(r.nextIntBound(bound).str);
        i = i + 1;
    };
    term.println(line);
};

func showBool(int seed) void {
    Random r = new Random(seed);
    str line = "nextBoolean:";
    int i = 0;
    while (i < 8) {
        line = line.con(" ").con(r.nextBoolean().str);
        i = i + 1;
    };
    term.println(line);
};

func run(int seed) void {
    term.println("seed ".con(seed.str));
    showInts(seed);
    showBound(seed, 100);
    showBound(seed, 64);
    showBool(seed);
};

run(42);
run(0 - 1);
run(12345);
