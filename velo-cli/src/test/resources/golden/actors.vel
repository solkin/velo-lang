Terminal term = new Terminal();

# Actor class — like a regular class, but every instance lives on its own
# daemon thread. Construction (`new Counter(0)`) and method calls
# (via `async` + `await`) are serialised through a private mailbox, so the
# actor's mutable state is implicitly thread-safe.

actor class Counter(int start) {
    int n = start;

    func bump() int {
        n += 1;
        n;
    };

    func value() int {
        n;
    };
};

actor[Counter] counter = new Counter(10);

# Synchronous form is `await async receiver.method(args)`:
#   `async ...`  starts the call and yields a `future[T]`;
#   `await ...`  blocks until that future resolves.
# The compiler refuses naked `counter.bump()` because `actor[Counter]`
# exposes no props, and refuses `await counter.bump()` because `await`
# only consumes futures.
term.println((await async counter.value()).str());
term.println((await async counter.bump()).str());
term.println((await async counter.bump()).str());
term.println((await async counter.value()).str());

# Spawn a second, independent counter to show that each actor owns its own state.
actor[Counter] other = new Counter(0);
term.println((await async other.bump()).str());
term.println((await async counter.value()).str());

# Parallel form: keep the future, await later. Both actors run concurrently
# between the two `async` lines and the matching `await`s.
future[int] fc = async counter.bump();
future[int] fo = async other.bump();
term.println((await fc).str());
term.println((await fo).str());
