# Explicit `return`, including early returns out of branches and loops.
Terminal term = new Terminal()

func sign(int x) int {
    if (x > 0) {
        return 1
    }
    if (x < 0) {
        return -1
    }
    return 0
}

# Early return straight out of a loop nested in an if.
func firstEven(array[int] a) int {
    int i = 0
    while (i < a.len()) {
        if (a[i] % 2 == 0) {
            return a[i]
        }
        i += 1
    }
    return -1
}

# Bare `return` from a void function.
func greet(str name) void {
    if (name == "") {
        return
    }
    term.println("Hi " + name)
}

term.println(sign(5).str())
term.println(sign(-3).str())
term.println(sign(0).str())

array[int] nums = new array[int](4)
nums[0] = 1
nums[1] = 3
nums[2] = 6
nums[3] = 8
term.println(firstEven(nums).str())

greet("")
greet("Velo")
