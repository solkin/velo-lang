Terminal term = new Terminal();

# A `data class` is an immutable value type: its state is exactly its
# constructor parameters, and it is copied by value across actor boundaries.
data class Point(int x, int y) {
    func sum() int { x + y; };
};

Point p = new Point(3, 4);
term.println(p.x.str());
term.println(p.y.str());
term.println(p.sum().str());

# Value equality: two points with equal fields are equal.
Point a = new Point(1, 2);
Point b = new Point(1, 2);
Point c = new Point(9, 9);
term.println(if (a == b) then "a==b" else "a!=b");
term.println(if (a == c) then "a==c" else "a!=c");

# Nested data classes compare and copy deeply.
data class Segment(Point from, Point to) {};
Segment s1 = new Segment(new Point(0, 0), new Point(1, 1));
Segment s2 = new Segment(new Point(0, 0), new Point(1, 1));
term.println(if (s1 == s2) then "seg-eq" else "seg-ne");

# A data class crosses an actor boundary by value, methods intact.
actor class Geometry() {
    func translate(Point p, int dx, int dy) Point {
        new Point(p.x + dx, p.y + dy);
    };
};

# `await receiver.method(...)` is the synchronous-call sugar — `async` is implied.
actor[Geometry] geo = new Geometry();
Point moved = await geo.translate(new Point(10, 20), 5, 6);
term.println(moved.x.str());
term.println(moved.y.str());
term.println(moved.sum().str());
