Terminal term = new Terminal();

# ============================================================
# Closures: functions that capture their defining scope
# ------------------------------------------------------------
# When a `func` literal is created, it captures a reference to
# the variables in the enclosing scope. The captured environment
# stays alive as long as the function value is reachable, even
# after the defining function has returned.
# ============================================================

# --- 1. Captured value: makeAdder -----------------------------
# `n` is a parameter of `makeAdder`. The returned lambda closes
# over it, so each adder remembers its own `n`.

func makeAdder(int n) func[int] {
    func(int x) int {
        x + n;
    };
};

func[int] add5 = makeAdder(5);
func[int] add10 = makeAdder(10);

term.println(add5(3).str());     # 8
term.println(add10(3).str());    # 13
term.println(add5(100).str());   # 105

# --- 2. Captured mutable state: counter -----------------------
# `count` is private to each counter instance. Two counters
# created from the same factory have independent state.

func makeCounter() func[int] {
    int count = 0;
    func() int {
        count = count + 1;
        count;
    };
};

func[int] c1 = makeCounter();
func[int] c2 = makeCounter();

term.println(c1().str());   # 1
term.println(c1().str());   # 2
term.println(c1().str());   # 3
term.println(c2().str());   # 1 — independent state
term.println(c1().str());   # 4

# --- 3. Two-step capture: shared accumulator ------------------
# A factory returns two closures sharing the same captured `total`.
# Modifying it through one closure is visible from the other.

class Pair(func[void] add, func[int] get) {};

func makeAccumulator() Pair {
    int total = 0;
    new Pair(
        func(int v) void { total = total + v; },
        func() int { total; }
    );
};

Pair acc = makeAccumulator();
acc.add(7);
acc.add(35);
term.println(acc.get().str());  # 42

# --- 4. Currying: function returning a function ---------------

func add(int a) func[int] {
    func(int b) int {
        a + b;
    };
};

func[int] addTen = add(10);
term.println(addTen(5).str());   # 15
term.println(add(3)(4).str());   # 7
