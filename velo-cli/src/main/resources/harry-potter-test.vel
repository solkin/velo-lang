Terminal term = new Terminal();

# Class for storing test results
class TestResults() {
    int gryffindor = 0;
    int hufflepuff = 0;
    int ravenclaw = 0;
    int slytherin = 0;
    
    # Methods for adding points to houses
    func addGryffindor(int points) void {
        gryffindor = gryffindor + points;
    };
    
    func addHufflepuff(int points) void {
        hufflepuff = hufflepuff + points;
    };
    
    func addRavenclaw(int points) void {
        ravenclaw = ravenclaw + points;
    };
    
    func addSlytherin(int points) void {
        slytherin = slytherin + points;
    };
    
    # Determines the house with maximum points
    func getHouse(int lang) str {
        int max = gryffindor;
        str house = "";
        
        if (lang == 0) {
            # English
            house = "Gryffindor";
            if (hufflepuff > max) {
                max = hufflepuff;
                house = "Hufflepuff";
            };
            if (ravenclaw > max) {
                max = ravenclaw;
                house = "Ravenclaw";
            };
            if (slytherin > max) {
                max = slytherin;
                house = "Slytherin";
            };
        } else {
            # Russian
            house = "Гриффиндор";
            if (hufflepuff > max) {
                max = hufflepuff;
                house = "Пуффендуй";
            };
            if (ravenclaw > max) {
                max = ravenclaw;
                house = "Когтевран";
            };
            if (slytherin > max) {
                max = slytherin;
                house = "Слизерин";
            };
        };
        house;
    };
    
    # Determines patronus based on house
    func getPatronus(str house, int lang) str {
        if (lang == 0) {
            # English
            if (house == "Gryffindor") {
                "Lion";
            } else if (house == "Hufflepuff") {
                "Badger";
            } else if (house == "Ravenclaw") {
                "Eagle";
            } else {
                "Snake";
            };
        } else {
            # Russian
            if (house == "Гриффиндор") {
                "Лев";
            } else if (house == "Пуффендуй") {
                "Барсук";
            } else if (house == "Когтевран") {
                "Орел";
            } else {
                "Змея";
            };
        };
    };
    
    # Determines magic wand based on house
    func getWand(str house, int lang) str {
        if (lang == 0) {
            # English
            if (house == "Gryffindor") {
                "Oak, 11 inches, phoenix feather core";
            } else if (house == "Hufflepuff") {
                "Hazel, 10 inches, unicorn hair core";
            } else if (house == "Ravenclaw") {
                "Cypress, 12 inches, veela hair core";
            } else {
                "Yew, 13 inches, dragon heartstring core";
            };
        } else {
            # Russian
            if (house == "Гриффиндор") {
                "Дуб, 11 дюймов, сердцевина из перья феникса";
            } else if (house == "Пуффендуй") {
                "Орешник, 10 дюймов, сердцевина из волос единорога";
            } else if (house == "Когтевран") {
                "Кипарис, 12 дюймов, сердцевина из волос вейлы";
            } else {
                "Тис, 13 дюймов, сердцевина из сердца дракона";
            };
        };
    };
};

# Function for displaying question and getting answer
func askQuestion(str question, array[str] options, int lang) int {
    term.println("");
    term.println(question);
    int i = 0;
    while (i < options.len) {
        term.println((i + 1).str.con(") ").con(options[i]));
        i = i + 1;
    };
    str prompt = "";
    if (lang == 0) {
        prompt = "Your choice (1-".con(options.len.str).con("): ");
    } else {
        prompt = "Ваш выбор (1-".con(options.len.str).con("): ");
    };
    term.print(prompt);
    str input = term.input();
    int choice = input.int;
    
    # Input validation
    if (choice < 1 | choice > options.len) {
        if (lang == 0) {
            term.println("Invalid choice, using option 1");
        } else {
            term.println("Неверный выбор, используется вариант 1");
        };
        choice = 1;
    };
    choice - 1; # Return index (0-based)
};

