# Gravity Defied — track data, decoded verbatim from the original levels.mrg (30 tracks, 3 leagues).
# Each track is a flat int array: [league, startX, startY, finishX, finishY, pointCount, x0,y0, x1,y1, ...]
# Point coordinates are the original raw units; the engine scales them by (v<<16)>>3 on load.

class Tracks() {
    func count() int { return 30 }

    func name(int i) str {
        if (i == 0) { return "Intro" };
        if (i == 1) { return "Shorty" };
        if (i == 2) { return "Slope" };
        if (i == 3) { return "Crackle" };
        if (i == 4) { return "Knolls" };
        if (i == 5) { return "Deep" };
        if (i == 6) { return "Cliff" };
        if (i == 7) { return "Hole" };
        if (i == 8) { return "Original" };
        if (i == 9) { return "Savvy" };
        if (i == 10) { return "Indoor" };
        if (i == 11) { return "Spikeholes" };
        if (i == 12) { return "Downhill" };
        if (i == 13) { return "Hillclimb" };
        if (i == 14) { return "Modesty" };
        if (i == 15) { return "Blocks" };
        if (i == 16) { return "Bumps" };
        if (i == 17) { return "Spikehops" };
        if (i == 18) { return "Pillar" };
        if (i == 19) { return "Trenches" };
        if (i == 20) { return "Floorboards" };
        if (i == 21) { return "Tip top" };
        if (i == 22) { return "Dantes Peak" };
        if (i == 23) { return "Abrupt" };
        if (i == 24) { return "Undertaker" };
        if (i == 25) { return "Liberty" };
        if (i == 26) { return "Intense" };
        if (i == 27) { return "100%" };
        if (i == 28) { return "Training day" };
        if (i == 29) { return "Trial again" };
        return "?"
    }

    func league(int i) int {
        if (i == 0) { return 0 };
        if (i == 1) { return 0 };
        if (i == 2) { return 0 };
        if (i == 3) { return 0 };
        if (i == 4) { return 0 };
        if (i == 5) { return 0 };
        if (i == 6) { return 0 };
        if (i == 7) { return 0 };
        if (i == 8) { return 0 };
        if (i == 9) { return 0 };
        if (i == 10) { return 1 };
        if (i == 11) { return 1 };
        if (i == 12) { return 1 };
        if (i == 13) { return 1 };
        if (i == 14) { return 1 };
        if (i == 15) { return 1 };
        if (i == 16) { return 1 };
        if (i == 17) { return 1 };
        if (i == 18) { return 1 };
        if (i == 19) { return 1 };
        if (i == 20) { return 2 };
        if (i == 21) { return 2 };
        if (i == 22) { return 2 };
        if (i == 23) { return 2 };
        if (i == 24) { return 2 };
        if (i == 25) { return 2 };
        if (i == 26) { return 2 };
        if (i == 27) { return 2 };
        if (i == 28) { return 2 };
        if (i == 29) { return 2 };
        return 0
    }

