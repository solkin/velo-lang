str C_RED = "#FF3838";       # the mystery saucer: the red top strip
str C_BULLET = "#FFFFFF";
str C_BOMB = "#FFFFFF";
str C_TEXT = "#FFFFFF";
str C_UFOSCORE = "#FFE100";

int CH_X = "X"[0];

