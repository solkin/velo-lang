# Space Invaders — the 1978 Taito arcade classic on a Canvas, in its original style: white
# pixel-art aliens (squid, crab, octopus) descending in a stepping formation that accelerates
# as their ranks thin, four green erodable shield bunkers, a red mystery saucer crossing the
# top for bonus points, the green laser cannon that fires one shot at a time, raining alien
# bombs, lives and score. The whole game advances on one actor that repaints off the event loop.
# Hold ◀ ▶ to move and FIRE to shoot — or drag the field to aim and tap it to fire.

include "lang/random.vel";

Terminal term = new Terminal();
Time time = new Time();
Ui ui = new Ui();
Colors colors = new Colors();
Icons icons = new Icons();
Random rng = new Random(12345);

